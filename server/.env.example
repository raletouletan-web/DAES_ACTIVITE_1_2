# ─── SMTP Configuration ───────────────────────────────────────────────────────
# Copy this file to server/.env and fill in SMTP_PASS before running the server.
# NEVER commit server/.env to version control.

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=patrice@savoirscope.fr
SMTP_PASS=YOUR_SMTP_PASSWORD_HERE
SMTP_FROM_NAME=Savoirscope – Activité 1

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
